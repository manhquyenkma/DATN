# ───────────────────────────────────────────────────────────────────────────
# Unity-generated (always rebuilt locally)
# ───────────────────────────────────────────────────────────────────────────
[Ll]ibrary/
[Tt]emp/
[Oo]bj/
[Bb]uild/
[Bb]uilds/
[Ll]ogs/
[Mm]emoryCaptures/
[Uu]serSettings/
[Aa]ssets/AssetStoreTools*

# Bake outputs — HOLA Map BakeBuildingsTool emits combined-mesh .asset
# files that are 100MB-1GB each (Sketchfab GLBs are high-poly). Always
# rebuildable via Tools > Build Game > HOLA Map > Bake.
Assets/_Data/BakedMeshes/
Assets/_Data/BakedMeshes.meta
Assets/Screenshots/

# IDE / OS / Visual Studio scaffolding
*.csproj
*.unityproj
*.suo
*.tmp
*.user
*.userprefs
*.pidb
*.booproj
*.svd
*.pdb
*.mdb
*.opendb
*.VC.db
.vs/
.idea/
.vscode/
*.swp
.DS_Store
Thumbs.db

# ───────────────────────────────────────────────────────────────────────────
# AI Training — Python virtual env (~5 GB) + heavyweights
# ───────────────────────────────────────────────────────────────────────────
AI_Training/phase_a_sentis/.venv/
AI_Training/phase_b_movement/.venv/
AI_Training/**/__pycache__/
AI_Training/**/*.pyc
AI_Training/**/.ipynb_checkpoints/

# Per-iter checkpoints (accumulate fast — keep only "best_model.zip" we care about)
AI_Training/phase_b_movement/checkpoints/v3_*/
AI_Training/phase_b_movement/checkpoints/iter*/
AI_Training/phase_b_movement/checkpoints/m2_*/
AI_Training/phase_b_movement/checkpoints/ppo_*_last.zip

# High-churn files written by overnight_loop — snapshot is volatile
AI_Training/overnight_v3.log
AI_Training/overnight_v3_state.json
AI_Training/overnight_v3_console.out
AI_Training/overnight.log
AI_Training/overnight_state.json
AI_Training/err.log
AI_Training/phase_a_sentis/err.log
# Machine-2 HEAVY loop variants
AI_Training/overnight_v3_m2.log
AI_Training/overnight_v3_m2_state.json
AI_Training/m2.out
AI_Training/m2.err

# Per-iter generated artifacts (regenerable)
AI_Training/phase_a_sentis/data/intents_v3.csv
AI_Training/phase_a_sentis/data/intents_v3_m2.csv
AI_Training/phase_a_sentis/data/intents_expanded.csv
# v4/v5/v6 training sets (~15MB each, regenerable via generate_dataset_v*.py)
AI_Training/phase_a_sentis/data/intents_v4.csv
AI_Training/phase_a_sentis/data/intents_v5.csv
AI_Training/phase_a_sentis/data/intents_v6.csv
AI_Training/phase_a_sentis/models/eval_iter*.json
AI_Training/phase_a_sentis/models/eval_m2_iter*.json
AI_Training/phase_a_sentis/models/training_log_*.json
AI_Training/phase_a_sentis/models/eval_realworld.json

# Unity batch-compile logs (regenerable)
compile_*.log
master_*.log
# Root-level *.log files from -executeMethod runs (Sim30.log, Bake.log, etc.)
/*.log

# Claude Code project-local MCP config (contains user-specific absolute paths)
.mcp.json
.claude/
