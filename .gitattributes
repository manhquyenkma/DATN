# Use LFS for binary AI artifacts so the repo stays light when re-trained
*.onnx           filter=lfs diff=lfs merge=lfs -text
*.pt             filter=lfs diff=lfs merge=lfs -text
*.zip            filter=lfs diff=lfs merge=lfs -text

# Unity 3D model imports (FBX may exceed GitHub's 100 MB per-blob limit)
*.fbx            filter=lfs diff=lfs merge=lfs -text
*.FBX            filter=lfs diff=lfs merge=lfs -text

# Normalize line endings on text files (Windows authors)
*.cs             text eol=lf
*.py             text eol=lf
*.md             text eol=lf
*.json           text eol=lf
*.csv            text eol=lf
*.yml            text eol=lf
